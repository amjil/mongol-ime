(ns mongol-ime-test.main
  (:require
   ["package:flutter/material.dart" :as m]
   ["package:flutter/foundation.dart" :refer [kIsWeb]]
   ["package:mongol/mongol.dart" :as mongol]
   [cljd.flutter :as f]
   [shared-ime.controller :as ctrl]
   [shared-ime.overlay-view :as overlay]
   [ime-core.remote-api :as remote]
   [ime-core.fst-engine :as fst]
   [ime-core.next-word :as next-word]))

(defonce editor-key (m/GlobalKey.))

(defn mongol-ime-field []
  (f/widget
   :managed [controller (m/TextEditingController.)
             focus-node (as-> (m/FocusNode
                               .onKeyEvent (fn [node event] (ctrl/handle-key-event event))) n
                          (doto n
                            (.addListener
                             (fn []
                               (if (.-hasFocus n)
                                 ;; Focus gained: register IME client callbacks
                                 (ctrl/register-client!
                                  {:replace-text!
                                   (fn [delete-len insert-str]
                                     (let [val (.-value controller)
                                           text (.-text val)
                                           sel (.-selection val)
                                           offset (max 0 (.-extentOffset sel))
                                           start-idx (max 0 (- offset delete-len))
                                           new-text (str (subs text 0 start-idx) insert-str (subs text offset))]
                                       (set! (.-value controller)
                                             (m/TextEditingValue.
                                              .text new-text
                                              .selection (m/TextSelection.collapsed .offset (+ start-idx (count insert-str)))))))

                                   :update-caret!
                                   (fn []
                                     (when-let [ctx (.-currentContext editor-key)]
                                       (let [^m/RenderBox rb (.findRenderObject ctx)
                                             global-offset (.localToGlobal rb m.Offset/zero)]
                                         (swap! ctrl/!ime-state assoc :caret-offset global-offset))))

                                   :get-context-text!
                                   (fn []
                                     (let [val (.-value controller)
                                           text (.-text val)
                                           sel (.-selection val)
                                           start-idx (max 0 (.-start sel))]
                                       (subs text 0 start-idx)))})
                                 
                                 ;; Focus lost: unregister IME
                                 (ctrl/unregister-client!))))))]
   
   ;; Watch text changes to refresh caret position and candidate overlay
   :bg-watcher ([^m/TextEditingValue val controller]
                (when-let [update-fn (:update-caret! @ctrl/!active-client)]
                  (update-fn)))

   (m/Center
    .child
    (m/Container
     .width 320.0 .height 400.0 .padding (m.EdgeInsets/all 16.0)
     .decoration (m/BoxDecoration .color m.Colors/white
                                  .border (m/Border.all .color m.Colors/grey .width 2.0)
                                  .borderRadius (m/BorderRadius.circular 8.0))
     .child
     (mongol/MongolTextField
      .key editor-key
      .controller controller
      .focusNode focus-node
      .maxLines nil
      .style (m/TextStyle .fontSize 20.0 .color m.Colors/black)
      .decoration (m/InputDecoration .hintText "Tap here to start typing..."
                                     .filled true
                                     .fillColor (m.Colors/grey 50)
                                     .border m.InputBorder/none))))))

(defn ^:async main []
  (m.WidgetsFlutterBinding/ensureInitialized)
  
  ;; 1. Configure Remote API for Web usage.
  ;; Update the base-url and paths if your backend server configuration changes.
  (remote/set-config! {:base-url "localhost:3003"
                       :candidate-api-path "/api/next_word/candidates"
                       :next-word-api-path "/api/next_word/list"})
  
  ;; 2. Initialize local FST and Next-Word engines ONLY if running on Desktop Native.
  ;; Web environments rely strictly on the remote HTTP APIs configured above.
  (when-not kIsWeb
    (await (fst/ensure-loaded))
    (await (next-word/ensure-loaded)))
  
  (f/run
   (m/MaterialApp
    .theme (m/ThemeData .useMaterial3 true 
                        .colorScheme (m/ColorScheme.fromSeed .seedColor m.Colors/blue)
                        .fontFamily "OyunQaganTig")
    .home (m/Scaffold .backgroundColor (m.Colors/grey 200)
                      .body (m/SafeArea .child (overlay/ime-global-wrapper (mongol-ime-field)))))))