(ns mongol-ime-test.main
  (:require
   ["package:flutter/material.dart" :as m]
   [mongol-ime.host :as host]
   [mongol-ime.toggle :as toggle]
   [cljd.flutter :as f]))

(defn main []
  (m.WidgetsFlutterBinding/ensureInitialized)

  (let [ime-enabled (atom true)
        text-controller (m/TextEditingController.)]
    (f/run
     (f/widget
      (m/MaterialApp
       .title "蒙古文输入法"
       .debugShowCheckedModeBanner false
       .home (m/Scaffold
              .appBar (m/AppBar
                       .title (m/Text "蒙古文输入法演示"))
              .body (m/Stack
                     .children
                     [(host/mongol-ime-host
                       {:enabled? @ime-enabled
                        :text-controller text-controller
                        :child (m/Center
                                .child (m/Padding
                                        .padding (m/EdgeInsets.all 32)
                                        .child (m/Column
                                                .mainAxisAlignment m.MainAxisAlignment/center
                                                .children
                                                [(m/Text
                                                  "请输入蒙古文（输入 a-z 字母）"
                                                  .style (m/TextStyle .fontSize 16))
                                                 (m/SizedBox .height 16)
                                                 (m/TextField
                                                  .controller text-controller
                                                  .decoration (m/InputDecoration
                                                               .labelText "输入框"
                                                               .hintText "输入 a-z 字母生成候选词"
                                                               .border (m/OutlineInputBorder))
                                                  .maxLines 5
                                                  .minLines 3)
                                                 (m/SizedBox .height 16)
                                                 (m/Text
                                                  "操作说明："
                                                  .style (m/TextStyle .fontSize 14 .fontWeight m.FontWeight/bold))
                                                 (m/Text
                                                  "• 输入 a-z 字母生成候选词"
                                                  .style (m/TextStyle .fontSize 12))
                                                 (m/Text
                                                  "• 数字 1-9 选择候选词"
                                                  .style (m/TextStyle .fontSize 12))
                                                 (m/Text
                                                  "• ↑↓ 切换候选"
                                                  .style (m/TextStyle .fontSize 12))
                                                 (m/Text
                                                  "• ←→ 翻页"
                                                  .style (m/TextStyle .fontSize 12))
                                                 (m/Text
                                                  "• Space/Enter 提交"
                                                  .style (m/TextStyle .fontSize 12))
                                                 (m/Text
                                                  "• Esc 取消"
                                                  .style (m/TextStyle .fontSize 12))])))})
                      (toggle/ime-toggle
                       {:enabled? @ime-enabled
                        :on-toggle (fn []
                                     (swap! ime-enabled not))})])))))))

